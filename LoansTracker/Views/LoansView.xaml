<Window x:Class="LoansTracker.Views.LoansView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loans Overview"
        Height="450"
        Width="650">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Loans table -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Loans}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  CanUserAddRows="False"
                  CanUserSortColumns="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Person"
                                    Binding="{Binding Person.Details}" 
                                    SortMemberPath="Person.Details"/>
                
                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding Amount, StringFormat={}{0:0.00} &#8364;}" 
                                    SortMemberPath="Amount"/>
                
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description}" 
                                    SortMemberPath="Description"/>

                <DataGridTextColumn Header="Date"
                                    Binding="{Binding Date, StringFormat=d}" 
                                    SortMemberPath="Date"/>

                <!-- Delete button -->
                <DataGridTemplateColumn Header="Delete" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteLoanCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}">
                                <TextBlock Text="🗑"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Total amount -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <TextBlock Text="Total:"
                       FontWeight="Bold"
                       Margin="0,0,6,0"/>

            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:0.00} &#8364;}"
                       FontWeight="Bold"/>
        </StackPanel>

    </Grid>
</Window>