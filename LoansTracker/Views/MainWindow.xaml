<Window x:Class="LoansTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoansTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="Loans Tracker" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <Button Content="Create Person" Click="CreatePerson_Click" Margin="0,4" />
            <Button Content="Add Loan" Click="CreateLoan_Click" Margin="0,4" />
            <Button Content="View Loans" Click="ViewLoans_Click" Margin="0,4" />
        </StackPanel>
    </Grid>
</Window>
